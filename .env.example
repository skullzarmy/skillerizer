# ── Copilot SDK ────────────────────────────────────────────────────────────────
# The GitHub Copilot CLI must be installed and in your PATH.
# Install: https://docs.github.com/en/copilot/how-tos/set-up/install-copilot-cli
# Verify:  copilot --version

# ── Authentication ─────────────────────────────────────────────────────────────
# Default: uses the Copilot CLI's logged-in user (run `copilot auth login`).
# Alternatively, set a GitHub token:
# GITHUB_TOKEN=ghp_your_github_pat_here

# ── BYOK (Bring Your Own Key) ─────────────────────────────────────────────────
# Override the default Copilot backend with your own provider.

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Ollama (local, no key needed)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection ───────────────────────────────────────────────────────────
# SDK model names: gpt-4o, gpt-4o-mini, claude-sonnet-4.5, llama3, etc.
# Default: gpt-4o-mini
# LLM_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
