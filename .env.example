# ── LLM Provider ──────────────────────────────────────────────────────────────
# GitHub Models (default — uses your GitHub PAT with "models" scope)
GITHUB_TOKEN=ghp_your_github_pat_here

# Optional: Use OpenAI directly instead
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai

# Optional: Use Ollama (local, no key needed)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Model selection ───────────────────────────────────────────────────────────
# GitHub Models identifiers: openai/gpt-4o, openai/gpt-4o-mini, meta/llama-3.1-70b-instruct, etc.
# Default: openai/gpt-4o-mini  (fast, free with GitHub token)
# LLM_MODEL=openai/gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
